# AES-256 암호화 키 — BrokerAccount appkey/appsecret 암호화용
# 반드시 32바이트(256bit) 문자열이어야 함
# 생성 방법: openssl rand -base64 24 | tr -d '=+/' | cut -c1-32
ENCRYPT_SECRET_KEY=

# Swagger server URL (로컬: http://localhost:8080, 운영: https://api.pongtrader.pro)
SPRINGDOC_SERVER_URL=http://localhost:8080
